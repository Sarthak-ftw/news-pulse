# App configuration
PORT=3001

# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/newspulse

# Scraper invocation path details
# Path to main.py script (relative to backend project directory)
PYTHON_SCRIPT_PATH=../scraper/main.py
# Python binary name (e.g., 'python', 'python3', or path to venv virtualenv binary)
PYTHON_BIN=python
