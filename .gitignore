# Environment files (most important — never commit these)
.env
.env.local
.env.development
.env.production
.env.test
.env*.local

# Python scraper cache, envs, and builds
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/.Python
**/venv/
**/env/
**/.venv/
**/*.egg-info/
**/dist/
**/build/
**/.pytest_cache/

# Node.js / Next.js dependencies, logs, and bundles
**/node_modules/
**/.next/
**/out/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.npm

# System files
.DS_Store
Thumbs.db
desktop.ini

# Logs
**/*.log
**/logs/
